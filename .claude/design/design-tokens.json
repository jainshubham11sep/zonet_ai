{
  "colors": {
    "background": {
      "primary": "#F7F6F3",
      "secondary": "#FFFFFF",
      "dark": "#1A1A1A"
    },
    "text": {
      "primary": "#1A1A1A",
      "secondary": "#686B6B",
      "light": "#FFFFFF"
    },
    "border": {
      "subtle": "#E6E4DF",
      "dark": "#1A1A1A"
    },
    "accent": {
      "yellow": "#E8C547",
      "blue": "#686BAB"
    },
    "interactive": {
      "button-dark": "#111111",
      "button-light": "#E8C547",
      "hover-shadow": "rgba(0, 0, 0, 0.05)"
    }
  },
  "typography": {
    "fontFamilies": {
      "heading": "'Playfair Display', serif",
      "body": "'Inter', 'Helvetica Now', 'Satoshi', sans-serif"
    },
    "typeScale": {
      "h1": {
        "fontSize": "48px",
        "lineHeight": "110%",
        "fontWeight": "600",
        "letterSpacing": "-0.5px"
      },
      "h2": {
        "fontSize": "32px",
        "lineHeight": "120%",
        "fontWeight": "600",
        "letterSpacing": "normal"
      },
      "h3": {
        "fontSize": "24px",
        "lineHeight": "130%",
        "fontWeight": "500",
        "letterSpacing": "normal"
      },
      "body": {
        "fontSize": "16px",
        "lineHeight": "150%",
        "fontWeight": "400",
        "letterSpacing": "normal"
      },
      "small": {
        "fontSize": "14px",
        "lineHeight": "140%",
        "fontWeight": "400",
        "letterSpacing": "normal"
      },
      "hero": {
        "fontSize": "72px",
        "lineHeight": "100%",
        "fontWeight": "600",
        "letterSpacing": "-1px"
      }
    }
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "2xl": "48px",
    "3xl": "64px",
    "4xl": "96px",
    "section": {
      "vertical": "80px",
      "hero": "96px"
    }
  },
  "components": {
    "button": {
      "height": "44px",
      "padding": "0 20px",
      "borderRadius": "999px",
      "fontSize": "14px",
      "fontWeight": "500",
      "transition": "200ms ease",
      "hover": {
        "transform": "translateY(-2px)",
        "boxShadow": "0 8px 20px rgba(0, 0, 0, 0.1)"
      }
    },
    "card": {
      "borderRadius": "16px",
      "padding": "20px",
      "border": "1px solid #E6E4DF",
      "boxShadow": "0 10px 30px rgba(0, 0, 0, 0.05)",
      "transition": "200ms ease",
      "hover": {
        "transform": "scale(1.02)",
        "boxShadow": "0 15px 40px rgba(0, 0, 0, 0.08)"
      }
    },
    "navbar": {
      "height": "72px",
      "padding": "24px",
      "background": "#FFFFFF",
      "fontSize": "14px",
      "fontWeight": "500"
    },
    "input": {
      "height": "44px",
      "padding": "12px 16px",
      "border": "1px solid #E6E4DF",
      "borderRadius": "8px",
      "fontSize": "14px",
      "transition": "150ms ease"
    }
  },
  "layout": {
    "maxWidth": "1280px",
    "gridColumns": 12,
    "gutter": "24px",
    "margin": "80px"
  },
  "accessibility": {
    "minContrastRatio": 4.5,
    "minTouchTarget": "44px"
  }
}
